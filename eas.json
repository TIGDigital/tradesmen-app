      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "hello@tigrowth.com",
        "ascAppId": "6778531543",
        "appleTeamId": "648JTT782L"
      }
    }
  }
